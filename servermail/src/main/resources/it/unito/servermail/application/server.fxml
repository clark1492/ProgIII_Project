<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox minHeight="300.0" minWidth="400.0" prefHeight="500.0" prefWidth="650.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.unito.servermail.controller.ServerController">
   <children>

      <!-- Header -->
      <Label alignment="CENTER" maxWidth="Infinity" prefHeight="50.0"
             style="-fx-background-color: #5DADE2;" text="Server Logs" textFill="WHITE"
             VBox.vgrow="NEVER">
         <font><Font name="System Bold Italic" size="24.0" /></font>
      </Label>

      <!-- Area log -->
      <TextArea fx:id="logsArea" editable="false" maxWidth="Infinity"
                style="-fx-background-color: #85C1E9;"
                wrapText="true" VBox.vgrow="ALWAYS">
         <font><Font name="System Monospaced" size="13.0" /></font>
         <padding><Insets bottom="5.0" left="5.0" right="5.0" top="5.0" /></padding>
      </TextArea>

   </children>
</VBox>
