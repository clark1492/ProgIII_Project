<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox minHeight="450.0" minWidth="350.0" prefHeight="450.0" prefWidth="350.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.unito.clientmail.controller.LoginController">
   <children>

      <!-- Header con logo -->
      <AnchorPane style="-fx-background-color: #85C1E9;"
                  minHeight="170.0" prefHeight="170.0" VBox.vgrow="NEVER">
         <children>
            <ImageView fitHeight="140.0" fitWidth="200.0" opacity="0.85"
                       pickOnBounds="true" preserveRatio="true"
                       AnchorPane.bottomAnchor="15.0" AnchorPane.topAnchor="15.0"
                       AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
               <image>
                  <Image url="@../img/Unito-logo.svg.png" />
               </image>
            </ImageView>
         </children>
      </AnchorPane>

      <!-- Body -->
      <AnchorPane VBox.vgrow="ALWAYS">
         <children>

            <!-- Label messaggi -->
            <Label fx:id="messageLabel" alignment="CENTER" textFill="#5dade2"
                   AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0"
                   AnchorPane.topAnchor="10.0" maxWidth="Infinity">
               <font><Font name="System Bold" size="13.0" /></font>
            </Label>

            <!-- Icona attenzione -->
            <ImageView fx:id="attentionImg" fitHeight="36.0" fitWidth="36.0"
                       pickOnBounds="true" preserveRatio="true" visible="false"
                       AnchorPane.bottomAnchor="10.0"
                       AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
               <image>
                  <Image url="@../img/icons8-high-importance-80.png" />
               </image>
            </ImageView>

            <!-- ===== Pannello Login ===== -->
            <AnchorPane fx:id="loginPane" visible="true"
                        style="-fx-background-color: transparent;"
                        AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
                        AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
               <children>
                  <!-- Icona utente -->
                  <ImageView fitHeight="28.0" fitWidth="28.0" opacity="0.5"
                             pickOnBounds="true" preserveRatio="true"
                             AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="45.0">
                     <image>
                        <Image url="@../img/toppng.com-user-account-management-logo-user-icon-561x561.png" />
                     </image>
                  </ImageView>
                  <!-- Icona lucchetto -->
                  <ImageView fitHeight="28.0" fitWidth="28.0" opacity="0.5"
                             pickOnBounds="true" preserveRatio="true"
                             AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="110.0">
                     <image>
                        <Image url="@../img/lock.png" />
                     </image>
                  </ImageView>
                  <!-- Campo email -->
                  <TextField fx:id="emailField" prefHeight="30.0" promptText="email"
                             style="-fx-background-color: transparent; -fx-border-color: #5DADE2; -fx-border-width: 0px 0px 2px 0px;"
                             AnchorPane.leftAnchor="60.0" AnchorPane.rightAnchor="20.0"
                             AnchorPane.topAnchor="45.0">
                     <font><Font size="14.0" /></font>
                  </TextField>
                  <!-- Campo password -->
                  <PasswordField fx:id="passwordField" prefHeight="30.0" promptText="password"
                                 style="-fx-background-color: transparent; -fx-border-color: #5DADE2; -fx-border-width: 0px 0px 2px 0px;"
                                 AnchorPane.leftAnchor="60.0" AnchorPane.rightAnchor="20.0"
                                 AnchorPane.topAnchor="110.0">
                  </PasswordField>
                  <!-- Bottoni -->
                  <Button fx:id="newUserButton" mnemonicParsing="false" onAction="#newUserOnAction"
                          prefHeight="40.0" prefWidth="120.0"
                          style="-fx-background-color: #5DADE2;" text="New User" textFill="WHITE"
                          AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="20.0">
                     <font><Font name="System Bold" size="12.0" /></font>
                  </Button>
                  <Button fx:id="loginButton" mnemonicParsing="false" onAction="#loginRequest"
                          prefHeight="40.0" prefWidth="120.0"
                          style="-fx-background-color: #5DADE2;" text="Log In" textFill="WHITE"
                          AnchorPane.bottomAnchor="15.0" AnchorPane.rightAnchor="20.0">
                     <font><Font name="System Bold" size="12.0" /></font>
                  </Button>
               </children>
            </AnchorPane>

            <!-- ===== Pannello Sign Up ===== -->
            <AnchorPane fx:id="signInPane" visible="false"
                        style="-fx-background-color: transparent;"
                        AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
                        AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
               <children>
                  <!-- Campo email -->
                  <TextField fx:id="newEmailField" prefHeight="30.0" promptText="email"
                             style="-fx-border-color: #5DADE2; -fx-background-color: transparent; -fx-border-width: 0px 0px 2px 0px;"
                             AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0"
                             AnchorPane.topAnchor="35.0">
                     <font><Font size="14.0" /></font>
                  </TextField>
                  <!-- Campo password -->
                  <PasswordField fx:id="newPasswordField" prefHeight="30.0" promptText="password"
                                 style="-fx-background-color: transparent; -fx-border-width: 0px 0px 2px 0px; -fx-border-color: #5DADE2;"
                                 AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0"
                                 AnchorPane.topAnchor="85.0">
                  </PasswordField>
                  <!-- Campo conferma password -->
                  <PasswordField fx:id="newPassConf" prefHeight="30.0" promptText="conferma password"
                                 style="-fx-background-color: transparent; -fx-border-width: 0px 0px 2px 0px; -fx-border-color: #5DADE2;"
                                 AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0"
                                 AnchorPane.topAnchor="135.0">
                  </PasswordField>
                  <!-- Bottoni -->
                  <Button fx:id="backButton" mnemonicParsing="false" onAction="#backOnAction"
                          prefHeight="40.0" prefWidth="120.0"
                          style="-fx-background-color: #5DADE2;" text="Back" textFill="WHITE"
                          AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="20.0">
                     <font><Font name="System Bold" size="12.0" /></font>
                  </Button>
                  <Button fx:id="signInButton" mnemonicParsing="false" onAction="#signInOnAction"
                          prefHeight="40.0" prefWidth="120.0"
                          style="-fx-background-color: #5DADE2;" text="Sign In" textFill="WHITE"
                          AnchorPane.bottomAnchor="15.0" AnchorPane.rightAnchor="20.0">
                     <font><Font name="System Bold" size="12.0" /></font>
                  </Button>
               </children>
            </AnchorPane>

         </children>
      </AnchorPane>
   </children>
</VBox>
