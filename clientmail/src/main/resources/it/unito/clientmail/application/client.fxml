<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane minHeight="600.0" minWidth="900.0" prefHeight="700.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="it.unito.clientmail.controller.ClientController">
   <children>
      <HBox AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
            AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
         <children>

            <!-- ===== Sidebar sinistra (larghezza fissa 200px) ===== -->
            <VBox fx:id="folders_box" prefWidth="200.0" minWidth="200.0" maxWidth="200.0"
                  style="-fx-background-color: #85C1E9;">
               <children>

                  <Button alignment="BASELINE_LEFT" graphicTextGap="15.0"
                          prefHeight="40.0" maxWidth="Infinity"
                          mnemonicParsing="false" onAction="#newMailOnAction"
                          style="-fx-background-color: #85C1E9;" text="New Mail" textFill="WHITE">
                     <graphic>
                        <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                           <image><Image url="@../img/pngwing.com (17).png" /></image>
                        </ImageView>
                     </graphic>
                     <font><Font name="System Bold" size="15.0" /></font>
                     <padding><Insets left="15.0" /></padding>
                  </Button>

                  <Label alignment="BASELINE_LEFT" graphicTextGap="15.0"
                         prefHeight="40.0" maxWidth="Infinity"
                         text="Account" textFill="WHITE">
                     <graphic>
                        <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                           <image><Image url="@../img/pngwing.com (10).png" /></image>
                        </ImageView>
                     </graphic>
                     <font><Font name="System Bold" size="15.0" /></font>
                     <padding><Insets left="15.0" /></padding>
                     <VBox.margin><Insets top="25.0" /></VBox.margin>
                  </Label>

                  <Label fx:id="lblUsername" alignment="BASELINE_LEFT"
                         prefHeight="40.0" maxWidth="Infinity"
                         text="email@email.it" textFill="WHITE">
                     <font><Font size="13.0" /></font>
                     <padding><Insets left="50.0" /></padding>
                  </Label>

                  <Label alignment="BASELINE_LEFT" graphicTextGap="15.0"
                         prefHeight="40.0" maxWidth="Infinity"
                         text="Folders" textFill="WHITE">
                     <graphic>
                        <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                           <image><Image url="@../img/pngwing.com (8).png" /></image>
                        </ImageView>
                     </graphic>
                     <font><Font name="System Bold" size="15.0" /></font>
                     <padding><Insets left="15.0" /></padding>
                     <VBox.margin><Insets top="25.0" /></VBox.margin>
                  </Label>

                  <Button alignment="BASELINE_LEFT" prefHeight="40.0" maxWidth="Infinity"
                          mnemonicParsing="false" onAction="#inboxOnAction"
                          style="-fx-background-color: #85C1E9;" text="Inbox" textFill="WHITE">
                     <font><Font size="15.0" /></font>
                     <padding><Insets left="50.0" /></padding>
                  </Button>

                  <Button alignment="BASELINE_LEFT" prefHeight="40.0" maxWidth="Infinity"
                          mnemonicParsing="false" onAction="#sentMailOnAction"
                          style="-fx-background-color: #85C1E9;" text="Sent" textFill="WHITE">
                     <font><Font size="15.0" /></font>
                     <padding><Insets left="50.0" /></padding>
                  </Button>

                  <Button alignment="BASELINE_LEFT" prefHeight="40.0" maxWidth="Infinity"
                          mnemonicParsing="false" onAction="#trashOnAction"
                          style="-fx-background-color: #85C1E9;" text="Bin" textFill="WHITE">
                     <font><Font size="15.0" /></font>
                     <padding><Insets left="50.0" /></padding>
                  </Button>

                  <!-- Spacer + errore server + logout -->
                  <AnchorPane style="-fx-background-color: #85C1E9;"
                              VBox.vgrow="ALWAYS" maxWidth="Infinity">
                     <children>
                        <ImageView fx:id="errorImg" fitHeight="40.0" fitWidth="40.0"
                                   pickOnBounds="true" preserveRatio="true" visible="false"
                                   AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
                                   AnchorPane.bottomAnchor="55.0">
                           <image><Image url="@../img/icons8-high-importance-80.png" /></image>
                        </ImageView>
                        <Label fx:id="errorLabel" text="SERVER UNREACHABLE"
                               textFill="#ff0505" visible="false"
                               AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0"
                               AnchorPane.bottomAnchor="100.0">
                        </Label>
                        <Button alignment="BASELINE_LEFT" graphicTextGap="15.0"
                                prefHeight="40.0" maxWidth="Infinity"
                                mnemonicParsing="false" onAction="#logoutOnAction"
                                style="-fx-background-color: #85C1E9;" text="Logout" textFill="WHITE"
                                AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                                AnchorPane.rightAnchor="0.0">
                           <font><Font name="System Bold" size="15.0" /></font>
                           <graphic>
                              <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                                 <image><Image url="@../img/icons8-shutdown-100.png" /></image>
                              </ImageView>
                           </graphic>
                           <padding><Insets left="15.0" /></padding>
                        </Button>
                     </children>
                  </AnchorPane>

               </children>
            </VBox>

            <!-- ===== Lista email (larghezza fissa 250px) ===== -->
            <VBox prefWidth="250.0" minWidth="250.0" maxWidth="250.0">
               <children>
                  <Label fx:id="lblFolder" alignment="BASELINE_LEFT" graphicTextGap="15.0"
                         prefHeight="40.0" maxWidth="Infinity"
                         style="-fx-background-color: #5DADE2;" text="Inbox" textFill="WHITE">
                     <font><Font name="System Bold" size="15.0" /></font>
                     <padding><Insets left="10.0" /></padding>
                     <graphic>
                        <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                           <image><Image url="@../img/263122.png" /></image>
                        </ImageView>
                     </graphic>
                  </Label>
                  <ListView fx:id="lstEmails" fixedCellSize="50.0"
                            style="-fx-background-color: #85C1E9;"
                            VBox.vgrow="ALWAYS" maxWidth="Infinity">
                     <padding><Insets bottom="5.0" left="5.0" right="5.0" top="5.0" /></padding>
                  </ListView>
               </children>
            </VBox>

            <!-- ===== Area dettaglio (si espande) ===== -->
            <AnchorPane fx:id="changePane" HBox.hgrow="ALWAYS">
               <children>

                  <!-- Modalità scrittura -->
                  <VBox fx:id="writeBox" style="-fx-background-color: #85C1E9;" visible="false"
                        AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
                        AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
                     <children>
                        <!-- Toolbar -->
                        <HBox alignment="CENTER_RIGHT" prefHeight="40.0" maxWidth="Infinity"
                              style="-fx-background-color: #5DADE2;">
                           <children>
                              <Button alignment="CENTER" graphicTextGap="10.0"
                                      mnemonicParsing="false" onAction="#sendOnAction"
                                      prefHeight="40.0" prefWidth="100.0"
                                      style="-fx-background-color: #5DADE2;" text="Send" textFill="WHITE">
                                 <graphic>
                                    <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                                       <image><Image url="@../img/pngwing.com (15).png" /></image>
                                    </ImageView>
                                 </graphic>
                                 <font><Font name="System Bold" size="14.0" /></font>
                              </Button>
                              <Button alignment="CENTER" graphicTextGap="10.0"
                                      mnemonicParsing="false" onAction="#undoOnAction"
                                      prefHeight="40.0" prefWidth="100.0"
                                      style="-fx-background-color: #5DADE2;" text="Undo" textFill="WHITE">
                                 <graphic>
                                    <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                                       <image><Image url="@../img/icons8-trash-can-100.png" /></image>
                                    </ImageView>
                                 </graphic>
                                 <font><Font name="System Bold" size="14.0" /></font>
                              </Button>
                           </children>
                        </HBox>
                        <!-- Campi header -->
                        <GridPane maxWidth="Infinity">
                           <columnConstraints>
                              <ColumnConstraints minWidth="80.0" prefWidth="80.0" maxWidth="80.0" />
                              <ColumnConstraints hgrow="ALWAYS" minWidth="100.0" />
                           </columnConstraints>
                           <rowConstraints>
                              <RowConstraints minHeight="30.0" prefHeight="30.0" />
                              <RowConstraints minHeight="30.0" prefHeight="30.0" />
                              <RowConstraints minHeight="30.0" prefHeight="30.0" />
                           </rowConstraints>
                           <children>
                              <Label text="Subject:" textFill="WHITE">
                                 <font><Font name="System Bold" size="14.0" /></font>
                                 <GridPane.margin><Insets left="10.0" /></GridPane.margin>
                              </Label>
                              <Label text="To:" textFill="WHITE" GridPane.rowIndex="1">
                                 <font><Font name="System Bold" size="14.0" /></font>
                                 <GridPane.margin><Insets left="10.0" /></GridPane.margin>
                              </Label>
                              <Label text="From:" textFill="WHITE" GridPane.rowIndex="2">
                                 <font><Font name="System Bold" size="14.0" /></font>
                                 <GridPane.margin><Insets left="10.0" /></GridPane.margin>
                              </Label>
                              <TextField fx:id="subjectField" prefHeight="30.0" maxWidth="Infinity"
                                         style="-fx-background-color: #85C1E9; -fx-text-fill: #FFFFFF;"
                                         GridPane.columnIndex="1">
                                 <font><Font size="14.0" /></font>
                              </TextField>
                              <TextField fx:id="toField" prefHeight="30.0" maxWidth="Infinity"
                                         style="-fx-background-color: #85C1E9; -fx-text-fill: #FFFFFF;"
                                         GridPane.columnIndex="1" GridPane.rowIndex="1">
                                 <font><Font size="14.0" /></font>
                              </TextField>
                              <Label fx:id="fromLabelW" prefHeight="30.0" maxWidth="Infinity"
                                     textFill="WHITE"
                                     GridPane.columnIndex="1" GridPane.rowIndex="2">
                                 <font><Font size="14.0" /></font>
                              </Label>
                           </children>
                        </GridPane>
                        <!-- Area testo -->
                        <TextArea fx:id="emailAreaW" style="-fx-background-color: #85C1E9;"
                                  wrapText="true" VBox.vgrow="ALWAYS" maxWidth="Infinity">
                           <font><Font size="14.0" /></font>
                           <VBox.margin><Insets bottom="5.0" right="5.0" /></VBox.margin>
                        </TextArea>
                     </children>
                  </VBox>

                  <!-- Modalità lettura -->
                  <VBox fx:id="readBox" style="-fx-background-color: #85C1E9;" visible="true"
                        AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
                        AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
                     <children>
                        <!-- Toolbar -->
                        <HBox prefHeight="40.0" maxWidth="Infinity"
                              style="-fx-background-color: #5DADE2;">
                           <children>
                              <Button fx:id="replyButton" alignment="CENTER" graphicTextGap="10.0"
                                      mnemonicParsing="false" onAction="#replyOnAction"
                                      prefHeight="40.0" HBox.hgrow="ALWAYS"
                                      style="-fx-background-color: #5DADE2;" text="Reply" textFill="WHITE">
                                 <graphic>
                                    <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                                       <image><Image url="@../img/icons8-left-2-100.png" /></image>
                                    </ImageView>
                                 </graphic>
                                 <font><Font name="System Bold" size="14.0" /></font>
                              </Button>
                              <Button fx:id="replyAllButton" alignment="CENTER" graphicTextGap="10.0"
                                      mnemonicParsing="false" onAction="#replyAllOnAction"
                                      prefHeight="40.0" HBox.hgrow="ALWAYS"
                                      style="-fx-background-color: #5DADE2;" text="ReplyAll" textFill="WHITE">
                                 <graphic>
                                    <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                                       <image><Image url="@../img/icons8-reply-all-arrow-100-2.png" /></image>
                                    </ImageView>
                                 </graphic>
                                 <font><Font name="System Bold" size="14.0" /></font>
                              </Button>
                              <Button fx:id="forwardButton" alignment="CENTER" graphicTextGap="10.0"
                                      mnemonicParsing="false" onAction="#forwardOnAction"
                                      prefHeight="40.0" HBox.hgrow="ALWAYS"
                                      style="-fx-background-color: #5DADE2;" text="Forward" textFill="WHITE">
                                 <graphic>
                                    <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                                       <image><Image url="@../img/icons8-forward-arrow-100.png" /></image>
                                    </ImageView>
                                 </graphic>
                                 <font><Font name="System Bold" size="14.0" /></font>
                              </Button>
                              <Button fx:id="deleteButton" alignment="CENTER" graphicTextGap="10.0"
                                      mnemonicParsing="false" onAction="#deleteOnAction"
                                      prefHeight="40.0" HBox.hgrow="ALWAYS"
                                      style="-fx-background-color: #5DADE2;" text="Delete" textFill="WHITE">
                                 <graphic>
                                    <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                                       <image><Image url="@../img/icons8-trash-can-100.png" /></image>
                                    </ImageView>
                                 </graphic>
                                 <font><Font name="System Bold" size="14.0" /></font>
                              </Button>
                           </children>
                        </HBox>
                        <!-- Intestazione email -->
                        <GridPane maxWidth="Infinity" style="-fx-background-color: #85C1E9;">
                           <columnConstraints>
                              <ColumnConstraints minWidth="80.0" prefWidth="100.0" maxWidth="100.0" />
                              <ColumnConstraints hgrow="ALWAYS" minWidth="100.0" />
                           </columnConstraints>
                           <rowConstraints>
                              <RowConstraints minHeight="30.0" prefHeight="30.0" />
                              <RowConstraints minHeight="30.0" prefHeight="30.0" />
                              <RowConstraints minHeight="30.0" prefHeight="30.0" />
                              <RowConstraints minHeight="30.0" prefHeight="30.0" />
                           </rowConstraints>
                           <children>
                              <Label text="Subject:" textFill="WHITE">
                                 <font><Font name="System Bold" size="14.0" /></font>
                                 <GridPane.margin><Insets left="10.0" /></GridPane.margin>
                              </Label>
                              <Label text="From:" textFill="WHITE" GridPane.rowIndex="1">
                                 <font><Font size="14.0" /></font>
                                 <GridPane.margin><Insets left="10.0" /></GridPane.margin>
                              </Label>
                              <Label text="To:" textFill="WHITE" GridPane.rowIndex="2">
                                 <font><Font size="14.0" /></font>
                                 <GridPane.margin><Insets left="10.0" /></GridPane.margin>
                              </Label>
                              <Label text="Date:" textFill="WHITE" GridPane.rowIndex="3">
                                 <font><Font size="14.0" /></font>
                                 <GridPane.margin><Insets left="10.0" /></GridPane.margin>
                              </Label>
                              <Label fx:id="subjectLabel" prefHeight="30.0" maxWidth="Infinity"
                                     textFill="WHITE" GridPane.columnIndex="1">
                                 <font><Font name="System Bold" size="14.0" /></font>
                              </Label>
                              <Label fx:id="fromLabelR" prefHeight="30.0" maxWidth="Infinity"
                                     textFill="WHITE" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                 <font><Font size="14.0" /></font>
                              </Label>
                              <Label fx:id="toLabelR" prefHeight="30.0" maxWidth="Infinity"
                                     textFill="WHITE" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                 <font><Font size="14.0" /></font>
                              </Label>
                              <Label fx:id="dateLabel" prefHeight="30.0" maxWidth="Infinity"
                                     textFill="WHITE" GridPane.columnIndex="1" GridPane.rowIndex="3">
                                 <font><Font size="14.0" /></font>
                              </Label>
                           </children>
                        </GridPane>
                        <!-- Corpo email -->
                        <TextArea fx:id="emailAreaR" editable="false"
                                  style="-fx-background-color: #85C1E9;"
                                  wrapText="true" VBox.vgrow="ALWAYS" maxWidth="Infinity">
                           <font><Font size="14.0" /></font>
                           <VBox.margin><Insets bottom="5.0" right="5.0" /></VBox.margin>
                        </TextArea>
                     </children>
                  </VBox>

               </children>
            </AnchorPane>

         </children>
      </HBox>
   </children>
</AnchorPane>
